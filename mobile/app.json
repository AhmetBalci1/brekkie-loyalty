{
  "expo": {
    "name": "Brekkie",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/brekkie-logo.png",
    "scheme": "mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "splash": {
      "image": "./assets/images/brekkie-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#004225"
    },
    "android": {
      "permissions": [
    "ACCESS_FINE_LOCATION",
    "ACCESS_COARSE_LOCATION",
    "ACCESS_BACKGROUND_LOCATION"
  ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/brekkie-logo.png",
        "backgroundColor": "#004225"
      },
      "googleServicesFile": "./google-services.json",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.brekkie.club"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
  "expo-router",

  [
    "expo-location",
    {
      "locationAlwaysAndWhenInUsePermission": "Yakınınızdaki Brekkie mağazalarını göstermek ve mağazaya yaklaştığınızda kampanya bildirimleri göndermek için konumunuza erişmemiz gerekiyor.",
      "isAndroidBackgroundLocationEnabled": true
    }
  ],

  [
    "expo-splash-screen",
    {
      "image": "./assets/images/brekkie-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#004225"
    }
  ],

  [
    "expo-notifications",
    {
      "icon": "./assets/images/brekkie-logo.png",
      "color": "#004225"
    }
  ]
],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "53ce0acd-3bd1-4e43-b346-2700492d1a78"
      }
    }
  }
}
